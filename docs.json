{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "bryel",
  "description": "LLM & agent observability \u2014 OpenTelemetry-native tracing for any framework.",
  "colors": {
    "primary": "#8c90d9",
    "light": "#b8bce9",
    "dark": "#6b6fcf"
  },
  "background": {
    "color": {
      "light": "#f7f5f1",
      "dark": "#16140f"
    }
  },
  "fonts": {
    "family": "Geist",
    "heading": {
      "family": "Geist"
    }
  },
  "appearance": {
    "default": "system"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://bryel.ai"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/typescript",
              "sdk/python",
              "sdk/browser",
              "sdk/http"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/feedback",
              "guides/datasets",
              "guides/coding-agents"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/bryel-ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://bryel.ai"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/bryel-ai",
      "x": "https://x.com/bryel_ai"
    }
  },
  "redirects": [
    {
      "source": "/installation",
      "destination": "/sdk/typescript"
    },
    {
      "source": "/frameworks/overview",
      "destination": "/sdk/typescript"
    },
    {
      "source": "/frameworks/vercel",
      "destination": "/sdk/typescript"
    },
    {
      "source": "/frameworks/opentelemetry",
      "destination": "/sdk/typescript"
    },
    {
      "source": "/frameworks/other",
      "destination": "/sdk/typescript"
    },
    {
      "source": "/frameworks/browser",
      "destination": "/sdk/browser"
    },
    {
      "source": "/api-reference/sdk-core",
      "destination": "/sdk/typescript"
    },
    {
      "source": "/api-reference/vercel",
      "destination": "/sdk/typescript"
    },
    {
      "source": "/api-reference/semconv",
      "destination": "/sdk/typescript"
    },
    {
      "source": "/api-reference/browser",
      "destination": "/sdk/browser"
    },
    {
      "source": "/api-reference/feedback",
      "destination": "/guides/feedback"
    }
  ]
}
