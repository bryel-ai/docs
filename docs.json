{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "bryel",
  "description": "LLM & agent observability — OpenTelemetry-native tracing for any framework.",
  "colors": {
    "primary": "#8c90d9",
    "light": "#b8bce9",
    "dark": "#6b6fcf"
  },
  "background": {
    "color": {
      "light": "#f7f5f1",
      "dark": "#16140f"
    }
  },
  "fonts": {
    "family": "Geist",
    "heading": {
      "family": "Geist"
    }
  },
  "appearance": {
    "default": "system"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://bryel.ai"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          { "group": "Get started", "pages": ["introduction", "quickstart", "installation"] },
          { "group": "Instrumentation", "pages": ["frameworks/overview", "frameworks/vercel", "frameworks/opentelemetry", "frameworks/other"] },
          { "group": "Concepts", "pages": ["concepts"] },
          { "group": "Guides", "pages": ["guides/feedback", "guides/datasets", "guides/coding-agents"] }
        ]
      },
      {
        "tab": "SDK reference",
        "groups": [
          { "group": "Packages", "pages": ["api-reference/sdk-core", "api-reference/vercel", "api-reference/feedback", "api-reference/semconv"] }
        ]
      }
    ]
  },
  "navbar": {
    "links": [{ "label": "GitHub", "href": "https://github.com/bryel-ai" }],
    "primary": { "type": "button", "label": "Dashboard", "href": "https://bryel.ai" }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/bryel-ai",
      "x": "https://x.com/bryel_ai"
    }
  }
}
